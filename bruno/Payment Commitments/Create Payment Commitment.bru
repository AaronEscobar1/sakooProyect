meta {
  name: Create Payment Commitment
  type: http
  seq: 1
}

post {
  url: {{base_url}}/api/v1/payments/commitments
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
    "amount": 150.50,
    "currency_id": 1,
    "due_date": "2026-06-20",
    "status": "PENDIENTE"
  }
}
